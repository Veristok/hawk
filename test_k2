-- Модуль Camera
local Camera = setmetatable({
    setColor = function(color)
        -- функция установки цвета
    end,
    
    setEnabled = function(enabled)
        for _, child in ipairs(Workspace:GetChildren()) do
            if child:IsA('Model') then
                local folder = child:FindFirstChildWhichIsA('Folder')
                if folder then
                    local defaultCameras = folder:FindFirstChild('DefaultCameras')
                    if defaultCameras then
                        for _, cameraModel in ipairs(defaultCameras:GetChildren()) do
                            if cameraModel:IsA('Model') then
                                local pingObject = game:GetService('ReplicatedStorage').Modules.Effects.PingObject:Clone()
                                pingObject.Parent = Workspace.CurrentCamera
                                pingObject.Adornee = cameraModel
                                pingObject.Enabled = true
                                
                                local frame = pingObject.Frame
                                if frame then
                                    frame.BackgroundColor3 = color
                                    
                                    local imageLabel = frame.ImageLabel
                                    if imageLabel then
                                        imageLabel.Image = 'rbxassetid://70956972762553'
                                    end
                                end
                                
                                local arrow = pingObject.Arrow
                                if arrow then
                                    arrow.ImageColor3 = color
                                end
                                
                                pingObject:FindFirstChild('testname')
                                pingObject.testname = cameraModel:FindFirstChild('Cam')
                            end
                        end
                    end
                end
            end
        end
    end,
    
    getEnabled = function()
        return enabled
    end,
    
    getColor = function()
        return color
    end,
}, {
    __index = function() end,
    __newindex = function(table, key, value)
        rawset(table, key, value)
    end,
})


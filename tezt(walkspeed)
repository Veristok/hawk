    Weapon.Font = Enum.Font.Code
    Weapon.TextSize = ESP.FontSize
    Weapon.TextStrokeTransparency = 0
    Weapon.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    Weapon.RichText = true

    local HealthBarContainer = Instance.new("Frame")
    HealthBarContainer.Parent = ESPFolder
    HealthBarContainer.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    HealthBarContainer.BackgroundTransparency = 1
    HealthBarContainer.BorderSizePixel = 0

    local HealthBarStroke = Instance.new("UIStroke")
    HealthBarStroke.Parent = HealthBarContainer

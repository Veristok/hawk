    local HealthBarFill = Instance.new("Frame")
    HealthBarFill.Parent = HealthBarContainer
    HealthBarFill.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
    HealthBarFill.BackgroundTransparency = 0
    HealthBarFill.BorderSizePixel = 0

    local HealthBarText = Instance.new("TextLabel")
    HealthBarText.Parent = ESPFolder
    HealthBarText.BackgroundTransparency = 1
    HealthBarText.TextColor3 = Color3.fromRGB(255, 255, 255)
    HealthBarText.Font = Enum.Font.Code
    HealthBarText.TextSize = ESP.Drawing.HealthBar.TextSize
    HealthBarText.TextStrokeTransparency = 0
    HealthBarText.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)

    local Box = Instance.new("Frame")
    Box.Parent = ESPFolder
    Box.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    Box.BackgroundTransparency = 0.75
    Box.BorderSizePixel = 0

    local Gradient1 = Instance.new("UIGradient")
    Gradient1.Parent = Box
    Gradient1.Enabled = ESP.Drawing.Boxes.GradientFill
    Gradient1.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, ESP.Drawing.Boxes.GradientFillRGB1),
        ColorSequenceKeypoint.new(1, ESP.Drawing.Boxes.GradientFillRGB2),
    })

    local Outline = Instance.new("UIStroke")
    Outline.Parent = Box
    Outline.Enabled = ESP.Drawing.Boxes.Gradient
    Outline.Transparency = 0
    Outline.Color = Color3.fromRGB(255, 255, 255)

    local Gradient2 = Instance.new("UIGradient")
    Gradient2.Parent = Outline
    Gradient2.Enabled = ESP.Drawing.Boxes.Gradient
    Gradient2.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, ESP.Drawing.Boxes.GradientRGB1),
        ColorSequenceKeypoint.new(1, ESP.Drawing.Boxes.GradientRGB2),
    })

    local Chams = Instance.new("Highlight")
    Chams.Parent = ESPFolder
    Chams.FillTransparency = 1
    Chams.OutlineTransparency = 0

    local cornerThickness = ESP.Drawing.Boxes.Corner.Thickness
    local cornerLength = ESP.Drawing.Boxes.Corner.Length
    
    local cornerProps = {
        Parent = ESPFolder,
        BackgroundColor3 = ESP.Drawing.Boxes.Corner.RGB,
        BackgroundTransparency = 0,
        BorderSizePixel = 0,
    }

    local LeftTopHorizontal = Instance.new("Frame")
    for k, v in pairs(cornerProps) do LeftTopHorizontal[k] = v end
    local LeftTopVertical = Instance.new("Frame")
    for k, v in pairs(cornerProps) do LeftTopVertical[k] = v end
    local RightTopHorizontal = Instance.new("Frame")
    for k, v in pairs(cornerProps) do RightTopHorizontal[k] = v end
    local RightTopVertical = Instance.new("Frame")
    for k, v in pairs(cornerProps) do RightTopVertical[k] = v end
    local LeftBottomHorizontal = Instance.new("Frame")
    for k, v in pairs(cornerProps) do LeftBottomHorizontal[k] = v end
    local LeftBottomVertical = Instance.new("Frame")
    for k, v in pairs(cornerProps) do LeftBottomVertical[k] = v end
    local RightBottomHorizontal = Instance.new("Frame")
    for k, v in pairs(cornerProps) do RightBottomHorizontal[k] = v end
    local RightBottomVertical = Instance.new("Frame")
    for k, v in pairs(cornerProps) do RightBottomVertical[k] = v end

    local RotationAngle = -45
    local LastTick = tick()

    local function HideESP()
        Box.Visible = false
        Name.Visible = false
        Weapon.Visible = false
        HealthBarContainer.Visible = false
        HealthBarText.Visible = false
        LeftTopHorizontal.Visible = false
        LeftTopVertical.Visible = false
        RightTopHorizontal.Visible = false
        RightTopVertical.Visible = false
        LeftBottomHorizontal.Visible = false
        LeftBottomVertical.Visible = false
        RightBottomHorizontal.Visible = false
        RightBottomVertical.Visible = false
        Chams.Enabled = false
    end

    local function CleanupESP()
        if Connection then Connection:Disconnect() end
        ESPFolder:Destroy()
        ActiveESPs[character] = nil
        if ActiveSkeletons[character] then
            for _, line in ipairs(ActiveSkeletons[character].lines) do line:Remove() end
            if ActiveSkeletons[character].connection then ActiveSkeletons[character].connection:Disconnect() end
            ActiveSkeletons[character] = nil
        end
    end

    local Connection
    Connection = RunService.RenderStepped:Connect(function()
        if not ESP.Enabled then HideESP() return end
        if not character or not character.Parent then CleanupESP() return end
        if not isValidPlayer(character) then CleanupESP() return end

        local rootPart = character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("UpperTorso")
        if not rootPart then HideESP() return end

        local pos, onScreen = Camera:WorldToViewportPoint(rootPart.Position)
        local dist = (Camera.CFrame.Position - rootPart.Position).Magnitude

        if onScreen and dist <= ESP.MaxDistance then
            local humanoid = character:FindFirstChild("Humanoid")
            local size = humanoid and humanoid.HipHeight or 2
            local scaleFactor = (size * Camera.ViewportSize.Y) / (pos.Z * 2)
            local w, h = 2.5 * scaleFactor, 4.75 * scaleFactor
            local verticalOffset = h * 0.175
            local dynamicCornerLength = math.min(cornerLength, w * 0.2, h * 0.2)

            local health, maxHealth = getPlayerHealth(character)
            local healthPercent = math.clamp((health / maxHealth) * 100, 0, 100)

            Chams.Adornee = character
            Chams.Enabled = ESP.Drawing.Chams.Enabled
            Chams.FillColor = ESP.Drawing.Chams.FillRGB
            Chams.OutlineColor = ESP.Drawing.Chams.OutlineRGB
            Chams.FillTransparency = ESP.Drawing.Chams.Fill_Transparency / 100
            Chams.OutlineTransparency = ESP.Drawing.Chams.Outline_Transparency / 100

            local cornerVisible = ESP.Drawing.Boxes.Corner.Enabled
            local cColor = ESP.Drawing.Boxes.Corner.RGB

            LeftTopHorizontal.Visible = cornerVisible
            LeftTopHorizontal.Position = UDim2.new(0, pos.X - w / 2, 0, pos.Y - h / 2 + verticalOffset)
            LeftTopHorizontal.Size = UDim2.new(0, dynamicCornerLength, 0, cornerThickness)
            LeftTopHorizontal.BackgroundColor3 = cColor

            LeftTopVertical.Visible = cornerVisible
            LeftTopVertical.Position = UDim2.new(0, pos.X - w / 2, 0, pos.Y - h / 2 + verticalOffset)
            LeftTopVertical.Size = UDim2.new(0, cornerThickness, 0, dynamicCornerLength)
            LeftTopVertical.BackgroundColor3 = cColor

            RightTopHorizontal.Visible = cornerVisible
            RightTopHorizontal.Position = UDim2.new(0, pos.X + w / 2 - dynamicCornerLength, 0, pos.Y - h / 2 + verticalOffset)
            RightTopHorizontal.Size = UDim2.new(0, dynamicCornerLength, 0, cornerThickness)
            RightTopHorizontal.BackgroundColor3 = cColor

            RightTopVertical.Visible = cornerVisible
            RightTopVertical.Position = UDim2.new(0, pos.X + w / 2 - cornerThickness, 0, pos.Y - h / 2 + verticalOffset)
            RightTopVertical.Size = UDim2.new(0, cornerThickness, 0, dynamicCornerLength)
            RightTopVertical.BackgroundColor3 = cColor

            LeftBottomHorizontal.Visible = cornerVisible
            LeftBottomHorizontal.Position = UDim2.new(0, pos.X - w / 2, 0, pos.Y + h / 2 + verticalOffset - cornerThickness)
            LeftBottomHorizontal.Size = UDim2.new(0, dynamicCornerLength, 0, cornerThickness)
            LeftBottomHorizontal.BackgroundColor3 = cColor

            LeftBottomVertical.Visible = cornerVisible
            LeftBottomVertical.Position = UDim2.new(0, pos.X - w / 2, 0, pos.Y + h / 2 + verticalOffset - dynamicCornerLength)
            LeftBottomVertical.Size = UDim2.new(0, cornerThickness, 0, dynamicCornerLength)
            LeftBottomVertical.BackgroundColor3 = cColor

            RightBottomHorizontal.Visible = cornerVisible
            RightBottomHorizontal.Position = UDim2.new(0, pos.X + w / 2 - dynamicCornerLength, 0, pos.Y + h / 2 + verticalOffset - cornerThickness)
            RightBottomHorizontal.Size = UDim2.new(0, dynamicCornerLength, 0, cornerThickness)
            RightBottomHorizontal.BackgroundColor3 = cColor

            RightBottomVertical.Visible = cornerVisible
            RightBottomVertical.Position = UDim2.new(0, pos.X + w / 2 - cornerThickness, 0, pos.Y + h / 2 + verticalOffset - dynamicCornerLength)
            RightBottomVertical.Size = UDim2.new(0, cornerThickness, 0, dynamicCornerLength)
            RightBottomVertical.BackgroundColor3 = cColor

            Box.Position = UDim2.new(0, pos.X - w / 2, 0, pos.Y - h / 2 + verticalOffset)
            Box.Size = UDim2.new(0, w, 0, h)

            local full = ESP.Drawing.Boxes.Full.Enabled
            local filled = ESP.Drawing.Boxes.Filled.Enabled

            Box.Visible = full or (cornerVisible and filled)
            Box.BackgroundTransparency = filled and ESP.Drawing.Boxes.Filled.Transparency or 1
            Outline.Enabled = full and ESP.Drawing.Boxes.Gradient

            if ESP.Drawing.HealthBar.Enabled then
                local barWidth = ESP.Drawing.HealthBar.Width
                local barPosition = ESP.Drawing.HealthBar.Position
                local healthBarHeight = h
                
                local healthBarX = barPosition == "Left" and (pos.X - w / 2 - barWidth - 2) or (pos.X + w / 2 + 2)
                local healthBarY = pos.Y - healthBarHeight / 2 + verticalOffset
                
                HealthBarContainer.Visible = true
                HealthBarContainer.Position = UDim2.new(0, healthBarX, 0, healthBarY)
                HealthBarContainer.Size = UDim2.new(0, barWidth, 0, healthBarHeight)
                HealthBarFill.Size = UDim2.new(1, 0, healthPercent / 100, 0)
                HealthBarFill.Position = UDim2.new(0, 0, 1 - (healthPercent / 100), 0)
                HealthBarFill.BackgroundColor3 = getHealthColor(healthPercent)
                
                if ESP.Drawing.HealthBar.ShowText then
                    HealthBarText.Visible = true
                    HealthBarText.Text = string.format("%.0f%%", healthPercent)
                    HealthBarText.TextSize = ESP.Drawing.HealthBar.TextSize
                    HealthBarText.Position = UDim2.new(0, healthBarX + barWidth / 2, 0, healthBarY + healthBarHeight / 2)
                else
                    HealthBarText.Visible = false
                end
            else
                HealthBarContainer.Visible = false
                HealthBarText.Visible = false
            end

            local currentTick = tick()
            local deltaTime = currentTick - LastTick
            RotationAngle = RotationAngle + deltaTime * ESP.Drawing.Boxes.RotationSpeed * math.cos(math.pi / 4 * currentTick - math.pi /

if ESP.Drawing.Skeleton.Enabled and not ActiveSkeletons[character] then
                createSkeletonESP(character)
            end
        else
            HideESP()
        end
    end)
end

-- Мониторинг обычных игроков (не Viewmodels)
local function MonitorPlayers()
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local character = player.Character
            if character and isValidPlayer(character) then
                task.spawn(function() CreateESP(character) end)
            end
            player.CharacterAdded:Connect(function(character)
                task.wait(0.2)
                CreateESP(character)
            end)
        end
    end
    
    Players.PlayerAdded:Connect(function(player)
        if player ~= LocalPlayer then
            player.CharacterAdded:Connect(function(character)
                task.wait(0.2)
                CreateESP(character)
            end)
        end
    end)
end

MonitorPlayers()

return ESP

local BONE_CONNECTIONS = {
    {"Head", "UpperTorso"},
    {"UpperTorso", "LowerTorso"},
    {"UpperTorso", "LeftUpperArm"},
    {"UpperTorso", "RightUpperArm"},
    {"LeftUpperArm", "LeftLowerArm"},
    {"RightUpperArm", "RightLowerArm"},
    {"LowerTorso", "LeftUpperLeg"},
    {"LowerTorso", "RightUpperLeg"},
    {"LeftUpperLeg", "LeftLowerLeg"},
    {"RightUpperLeg", "RightLowerLeg"},
}

local function getPlayerHealth(character)
    if not character then return 0, 100 end
    local humanoid = character:FindFirstChild("Humanoid")
    if humanoid then return humanoid.Health, humanoid.MaxHealth end
    return 100, 100
end

local function getHealthColor(percent)
    if percent >= 70 then
        return ESP.Drawing.HealthBar.ColorHigh
    elseif percent >= 30 then
        local t = (percent - 30) / 40
        return Color3.new(
            ESP.Drawing.HealthBar.ColorHigh.R * t + ESP.Drawing.HealthBar.ColorMid.R * (1 - t),
            ESP.Drawing.HealthBar.ColorHigh.G * t + ESP.Drawing.HealthBar.ColorMid.G * (1 - t),
            ESP.Drawing.HealthBar.ColorHigh.B * t + ESP.Drawing.HealthBar.ColorMid.B * (1 - t)
        )
    else
        local t = percent / 30
        return Color3.new(
            ESP.Drawing.HealthBar.ColorMid.R * t + ESP.Drawing.HealthBar.ColorLow.R * (1 - t),
            ESP.Drawing.HealthBar.ColorMid.G * t + ESP.Drawing.HealthBar.ColorLow.G * (1 - t),
            ESP.Drawing.HealthBar.ColorMid.B * t + ESP.Drawing.HealthBar.ColorLow.B * (1 - t)
        )
    end
end

local function isValidPlayer(model)
    if not model or not model.Parent then return false end
    if model == LocalPlayer.Character then return false end
    local humanoid = model:FindFirstChild("Humanoid")
    if not humanoid or humanoid.Health <= 0 then return false end
    return model:FindFirstChild("HumanoidRootPart") ~= nil
end

local function findWeaponInCharacter(character)
    if not character then return nil end
    return character:FindFirstChildWhichIsA("Tool")
end

local function getBonesFromCharacter(character)
    local bones = {}
    local boneNames = {"Head", "UpperTorso", "LowerTorso", "LeftUpperArm", "RightUpperArm", 
                       "LeftLowerArm", "RightLowerArm", "LeftUpperLeg", "RightUpperLeg", 
                       "LeftLowerLeg", "RightLowerLeg"}
    for _, name in ipairs(boneNames) do
        local bone = character:FindFirstChild(name)
        if bone and bone:IsA("BasePart") then
            bones[name] = bone
        end
    end
    return bones
end

local function createSkeletonESP(character)
    if not character or ActiveSkeletons[character] then return end
    if not isValidPlayer(character) then return end

    local bones = getBonesFromCharacter(character)
    for _, connection in ipairs(BONE_CONNECTIONS) do
        if not bones[connection[1]] or not bones[connection[2]] then
            return
        end
    end

    local skeletonLines = {}
    for _ in ipairs(BONE_CONNECTIONS) do
        local line = Drawing.new("Line")
        line.Visible = false
        line.Color = ESP.Drawing.Skeleton.RGB
        line.Thickness = ESP.Drawing.Skeleton.Thickness
        line.Transparency = 1
        table.insert(skeletonLines, line)
    end

    local skeletonData = { lines = skeletonLines, bones = bones, character = character }
    ActiveSkeletons[character] = skeletonData

    local connection = RunService.RenderStepped:Connect(function()
        if not ESP.Enabled or not ESP.Drawing.Skeleton.Enabled then
            for _, line in ipairs(skeletonLines) do line.Visible = false end
            return
        end

        local torso = bones["UpperTorso"] or bones["LowerTorso"]
        if not torso then
            for _, line in ipairs(skeletonLines) do line.Visible = false end
            return
        end

        local distance = (Camera.CFrame.Position - torso.Position).Magnitude
        if distance > ESP.MaxDistance then
            for _, line in ipairs(skeletonLines) do line.Visible = false end
            return
        end

        for i, connection in ipairs(BONE_CONNECTIONS) do
            local bone1, bone2 = bones[connection[1]], bones[connection[2]]
            local line = skeletonLines[i]
            if bone1 and bone2 and line then
                local pos1, onScreen1 = Camera:WorldToViewportPoint(bone1.Position)
                local pos2, onScreen2 = Camera:WorldToViewportPoint(bone2.Position)
                if onScreen1 and onScreen2 then
                    line.From = Vector2.new(pos1.X, pos1.Y)
                    line.To = Vector2.new(pos2.X, pos2.Y)
                    line.Visible = true
                    line.Color = ESP.Drawing.Skeleton.RGB
                    line.Thickness = ESP.Drawing.Skeleton.Thickness
                else
                    line.Visible = false
                end
            elseif line then
                line.Visible = false
            end
        end
    end)
    skeletonData.connection = connection
end


local function getHealthColor(percent)
	if percent >= 70 then
		return ESP.Drawing.HealthBar.ColorHigh
	elseif percent >= 30 then
		local t = (percent - 30) / 40
		return Color3.new(
			ESP.Drawing.HealthBar.ColorHigh.R * t + ESP.Drawing.HealthBar.ColorMid.R * (1 - t),
			ESP.Drawing.HealthBar.ColorHigh.G * t + ESP.Drawing.HealthBar.ColorMid.G * (1 - t),
			ESP.Drawing.HealthBar.ColorHigh.B * t + ESP.Drawing.HealthBar.ColorMid.B * (1 - t)
		)
	else
		local t = percent / 30
		return Color3.new(
			ESP.Drawing.HealthBar.ColorMid.R * t + ESP.Drawing.HealthBar.ColorLow.R * (1 - t),
			ESP.Drawing.HealthBar.ColorMid.G * t + ESP.Drawing.HealthBar.ColorLow.G * (1 - t),
			ESP.Drawing.HealthBar.ColorMid.B * t + ESP.Drawing.HealthBar.ColorLow.B * (1 - t)
		)
	end
end

local BONE_CONNECTIONS = {
	{ "torso", "shoulder1" },
	{ "torso", "shoulder2" },
	{ "torso", "hip1" },
	{ "torso", "hip2" },
	{ "torso", "head" },
	{ "shoulder1", "arm1" },
	{ "shoulder2", "arm2" },
	{ "hip1", "leg1" },
	{ "hip2", "leg2" },
}

local function getTorso(model)
	local torso = model:FindFirstChild("torso")
	if torso and torso:IsA("BasePart") then
		return torso
	end
	local parts = {"HumanoidRootPart", "UpperTorso", "Head"}
	for _, partName in ipairs(parts) do
		local part = model:FindFirstChild(partName)
		if part and part:IsA("BasePart") then
			return part
		end
	end
	return nil
end

local function isValidPlayer(model)
	if not model or not model.Parent then
		return false
	end
	if model.Name == LocalPlayer.Name or model.Name == "LocalViewmodel" then
		return false
	end
	local humanoid = model:FindFirstChild("Humanoid")
	if not humanoid or humanoid.Health <= 0 then
		return false
	end
	return true
end

local function findWeaponInCharacter(character)
	for _, child in pairs(character:GetChildren()) do
		if child:IsA("Model") and child:GetAttribute("item_type") then
			return child
		end
	end
	return nil
end

local function createSkeletonESP(character)
	if not character or ActiveSkeletons[character] then
		return
	end
	if not isValidPlayer(character) then
		return
	end

	local bones = {}
	local requiredBones = { "torso", "head", "shoulder1", "shoulder2", "arm1", "arm2", "hip1", "hip2", "leg1", "leg2" }
	local hasAllBones = true

	for _, boneName in ipairs(requiredBones) do
		local bone = character:FindFirstChild(boneName)
		if bone and bone:IsA("BasePart") then
			bones[boneName] = bone
		else
			hasAllBones = false
			break
		end
	end

	if not hasAllBones then
		return
	end

	local skeletonLines = {}
	for i = 1, #BONE_CONNECTIONS do
		local line = Drawing.new("Line")
		line.Visible = false
		line.Color = ESP.Drawing.Skeleton.RGB
		line.Thickness = ESP.Drawing.Skeleton.Thickness
		line.Transparency = 1
		skeletonLines[i] = line
	end

	local skeletonData = {
		lines = skeletonLines,
		bones = bones,
		character = character,
	}

	ActiveSkeletons[character] = skeletonData

	local connection = RunService.RenderStepped:Connect(function()
		if not ESP.Enabled or not ESP.Drawing.Skeleton.Enabled then
			for _, line in ipairs(skeletonLines) do
				line.Visible = false
			end
			return
		end

		local torso = bones["torso"]
		if not torso or torso.Transparency >= 1 then
			for _, line in ipairs(skeletonLines) do
				line.Visible = false
			end
			return
		end

		local distance = (Camera.CFrame.Position - torso.Position).Magnitude
		if distance > ESP.MaxDistance then
			for _, line in ipairs(skeletonLines) do
				line.Visible = false
			end
			return
		end

		for i, conn in ipairs(BONE_CONNECTIONS) do
			local bone1, bone2 = bones[conn[1]], bones[conn[2]]
			local line = skeletonLines[i]
			if bone1 and bone2 and line then
				local pos1, on1 = Camera:WorldToViewportPoint(bone1.Position)
				local pos2, on2 = Camera:WorldToViewportPoint(bone2.Position)
				if on1 and on2 then
					line.From = Vector2.new(pos1.X, pos1.Y)
					line.To = Vector2.new(pos2.X, pos2.Y)
					line.Visible = true
				else
					line.Visible = false
				end
			elseif line then
				line.Visible = false
			end
		end
	end)

	skeletonData.connection = connection
end


	HealthBarContainer.Parent = ESPFolder
	HealthBarContainer.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	HealthBarContainer.BackgroundTransparency = 1
	HealthBarContainer.BorderSizePixel = 0
	
	local HealthBarStroke = Instance.new("UIStroke")
	HealthBarStroke.Parent = HealthBarContainer
	HealthBarStroke.Thickness = 0.5
	HealthBarStroke.Color = Color3.fromRGB(0, 0, 0)
	HealthBarStroke.Transparency = 0.3
	HealthBarStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	
	local HealthBarFill = Instance.new("Frame")
	HealthBarFill.Parent = HealthBarContainer
	HealthBarFill.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
	HealthBarFill.BackgroundTransparency = 0
	HealthBarFill.BorderSizePixel = 0
	HealthBarFill.Size = UDim2.new(1, 0, 0, 0)
	
	local HealthBarText = Instance.new("TextLabel")
	HealthBarText.Name = "HealthBarText"
	HealthBarText.Parent = ESPFolder
	HealthBarText.Position = UDim2.new(0.5, 0, 0, 0)
	HealthBarText.Size = UDim2.new(0, 40, 0, 14)
	HealthBarText.AnchorPoint = Vector2.new(0.5, 0.5)
	HealthBarText.BackgroundTransparency = 1
	HealthBarText.TextColor3 = Color3.fromRGB(255, 255, 255)
	HealthBarText.Font = Enum.Font.Code
	HealthBarText.TextSize = ESP.Drawing.HealthBar.TextSize
	HealthBarText.TextStrokeTransparency = 0
	HealthBarText.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
	HealthBarText.Text = "100%"

	-- Бокс
	local Box = Instance.new("Frame")
	Box.Name = "Box"
	Box.Parent = ESPFolder
	Box.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	Box.BackgroundTransparency = 0.75
	Box.BorderSizePixel = 0
	Box.Visible = false

	local Gradient1 = Instance.new("UIGradient")
	Gradient1.Parent = Box
	Gradient1.Enabled = ESP.Drawing.Boxes.GradientFill
	Gradient1.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, ESP.Drawing.Boxes.GradientFillRGB1),
		ColorSequenceKeypoint.new(1, ESP.Drawing.Boxes.GradientFillRGB2),
	})

	local Outline = Instance.new("UIStroke")
	Outline.Parent = Box
	Outline.Enabled = ESP.Drawing.Boxes.Gradient
	Outline.Transparency = 0
	Outline.Color = Color3.fromRGB(255, 255, 255)
	Outline.LineJoinMode = Enum.LineJoinMode.Miter

	local Gradient2 = Instance.new("UIGradient")
	Gradient2.Parent = Outline
	Gradient2.Enabled = ESP.Drawing.Boxes.Gradient
	Gradient2.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, ESP.Drawing.Boxes.GradientRGB1),
		ColorSequenceKeypoint.new(1, ESP.Drawing.Boxes.GradientRGB2),
	})

	-- Углы
	local cornerThickness = ESP.Drawing.Boxes.Corner.Thickness
	local cornerLength = ESP.Drawing.Boxes.Corner.Length
	
	local corners = {}
	local cornerNames = {"LeftTopHorizontal", "LeftTopVertical", "RightTopHorizontal", "RightTopVertical", "LeftBottomHorizontal", "LeftBottomVertical", "RightBottomHorizontal", "RightBottomVertical"}
	
	for _, name in ipairs(cornerNames) do
		local corner = Instance.new("Frame")
		corner.Name = name
		corner.Parent = ESPFolder
		corner.BackgroundColor3 = ESP.Drawing.Boxes.Corner.RGB
		corner.BackgroundTransparency = 0
		corner.BorderSizePixel = 0
		corner.Visible = false
		corners[name] = corner
	end

	-- Чамсы
	local Chams = Instance.new("Highlight")
	Chams.Name = "Chams"
	Chams.Parent = ESPFolder
	Chams.FillTransparency = 1
	Chams.OutlineTransparency = 0
	Chams.OutlineColor = Color3.fromRGB(119, 120, 255)
	Chams.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
	Chams.Enabled = false

	local RotationAngle = -45
	local LastTick = tick()

	local Connection
	local function CleanupESP()
		if Connection then Connection:Disconnect() end
		if ESPFolder then ESPFolder:Destroy() end
		ActiveESPs[CharacterModel] = nil
		if ActiveSkeletons[CharacterModel] then
			for _, line in ipairs(ActiveSkeletons[CharacterModel].lines or {}) do
				if line then line:Remove() end
			end
			ActiveSkeletons[CharacterModel] = nil
		end
	end

	Connection = RunService.RenderStepped:Connect(function()
		if not ESP.Enabled then
			if Box then Box.Visible = false end
			if NameLabel then NameLabel.Visible = false end
			if WeaponLabel then WeaponLabel.Visible = false end
			if HealthBarContainer then HealthBarContainer.Visible = false end
			if HealthBarText then HealthBarText.Visible = false end
			if Chams then Chams.Enabled = false end
			for _, corner in pairs(corners) do corner.Visible = false end
			return
		end

		if not CharacterModel or not CharacterModel.Parent then
			CleanupESP()
			return
		end

		local humanoid = CharacterModel:FindFirstChild("Humanoid")
		if not humanoid or humanoid.Health <= 0 then
			Box.Visible = false
			NameLabel.Visible = false
			WeaponLabel.Visible = false
			HealthBarContainer.Visible = false
			HealthBarText.Visible = false
			Chams.Enabled = false
			for _, corner in pairs(corners) do corner.Visible = false end
			return
		end

		local torso = getTorso(CharacterModel)
		if not torso then
			Box.Visible = false
			return
		end

		local Pos, OnScreen = Camera:WorldToScreenPoint(torso.Position)
		local Dist = (Camera.CFrame.Position - torso.Position).Magnitude / 3.5714285714

		if OnScreen and Dist <= ESP.MaxDistance then
			local Size = torso.Size.Y
			local scaleFactor = (Size * Camera.ViewportSize.Y) / (Pos.Z * 2)
			local w, h = 2.5 * scaleFactor, 4.75 * scaleFactor
			local verticalOffset = h * 0.175
			local dynamicCornerLength = math.min(cornerLength, w * 0.2, h * 0.2)

			local health = humanoid.Health
			local maxHealth = humanoid.MaxHealth
			local healthPercent = (health / maxHealth) * 100
			local healthPercentClamped = math.clamp(healthPercent, 0, 100)

			-- Бокс
			local full = ESP.Drawing.Boxes.Full.Enabled
			local corner = ESP.Drawing.Boxes.Corner.Enabled
			local filled = ESP.Drawing.Boxes.Filled.Enabled
			
			if full or (corner and filled) then
				Box.Visible = true
				Box.Position = UDim2.new(0, Pos.X - w / 2, 0, Pos.Y - h / 2 + verticalOffset)
				Box.Size = UDim2.new(0, w, 0, h)
				if filled then
					Box.BackgroundTransparency = ESP.Drawing.Boxes.Filled.Transparency
				else
					Box.BackgroundTransparency = 1
				end
				Outline.Enabled = full and ESP.Drawing.Boxes.Gradient
			else
				Box.Visible = false
			end

	-- Углы
			if corner then
				local cColor = ESP.Drawing.Boxes.Corner.RGB
				for _, cornerFrame in pairs(corners) do
					cornerFrame.BackgroundColor3 = cColor
				end
				
				corners["LeftTopHorizontal"].Visible = true
				corners["LeftTopHorizontal"].Position = UDim2.new(0, Pos.X - w / 2, 0, Pos.Y - h / 2 + verticalOffset)
				corners["LeftTopHorizontal"].Size = UDim2.new(0, dynamicCornerLength, 0, cornerThickness)
				
				corners["LeftTopVertical"].Visible = true
				corners["LeftTopVertical"].Position = UDim2.new(0, Pos.X - w / 2, 0, Pos.Y - h / 2 + verticalOffset)
				corners["LeftTopVertical"].Size = UDim2.new(0, cornerThickness, 0, dynamicCornerLength)
				
				corners["RightTopHorizontal"].Visible = true
				corners["RightTopHorizontal"].Position = UDim2.new(0, Pos.X + w / 2 - dynamicCornerLength, 0, Pos.Y - h / 2 + verticalOffset)
				corners["RightTopHorizontal"].Size = UDim2.new(0, dynamicCornerLength, 0, cornerThickness)
				
				corners["RightTopVertical"].Visible = true
				corners["RightTopVertical"].Position = UDim2.new(0, Pos.X + w / 2 - cornerThickness, 0, Pos.Y - h / 2 + verticalOffset)
				corners["RightTopVertical"].Size = UDim2.new(0, cornerThickness, 0, dynamicCornerLength)
				
				corners["LeftBottomHorizontal"].Visible = true
				corners["LeftBottomHorizontal"].Position = UDim2.new(0, Pos.X - w / 2, 0, Pos.Y + h / 2 + verticalOffset - cornerThickness)
				corners["LeftBottomHorizontal"].Size = UDim2.new(0, dynamicCornerLength, 0, cornerThickness)
				
				corners["LeftBottomVertical"].Visible = true
				corners["LeftBottomVertical"].Position = UDim2.new(0, Pos.X - w / 2, 0, Pos.Y + h / 2 + verticalOffset - dynamicCornerLength)
				corners["LeftBottomVertical"].Size = UDim2.new(0, cornerThickness, 0, dynamicCornerLength)
				
				corners["RightBottomHorizontal"].Visible = true
				corners["RightBottomHorizontal"].Position = UDim2.new(0, Pos.X + w / 2 - dynamicCornerLength, 0, Pos.Y + h / 2 + verticalOffset - cornerThickness)
				corners["RightBottomHorizontal"].Size = UDim2.new(0, dynamicCornerLength, 0, cornerThickness)
				
				corners["RightBottomVertical"].Visible = true
				corners["RightBottomVertical"].Position = UDim2.new(0, Pos.X + w / 2 - cornerThickness, 0, Pos.Y + h / 2 + verticalOffset - dynamicCornerLength)
				corners["RightBottomVertical"].Size = UDim2.new(0, cornerThickness, 0, dynamicCornerLength)
			else
				for _, cornerFrame in pairs(corners) do
					cornerFrame.Visible = false
				end
			end

			-- Анимация градиента
			local CurrentTick = tick()
			local DeltaTime = CurrentTick - LastTick
			RotationAngle = RotationAngle + DeltaTime * ESP.Drawing.Boxes.RotationSpeed * math.cos(math.pi / 4 * CurrentTick - math.pi / 2)
			if ESP.Drawing.Boxes.Animate then
				Gradient1.Rotation = RotationAngle
				Gradient2.Rotation = RotationAngle
			else
				Gradient1.Rotation = -45
				Gradient2.Rotation = -45
			end
			LastTick = CurrentTick

			-- Имя
			if ESP.Drawing.Names.Enabled then
				NameLabel.Visible = true
				local nameText = CharacterModel.Name
				if ESP.Drawing.Distances.Enabled then
					nameText = string.format("%s [%d]", nameText, math.floor(Dist))
				end
				NameLabel.Text = nameText
				NameLabel.TextColor3 = ESP.Drawing.Names.RGB
				NameLabel.Position = UDim2.new(0, Pos.X, 0, Pos.Y - h / 2 - 9 + verticalOffset)
			else
				NameLabel.Visible = false
			end

			-- Оружие
			if ESP.Drawing.Weapons.Enabled then
				local weaponModel = findWeaponInCharacter(CharacterModel)
				if weaponModel then
					WeaponLabel.Visible = true
					WeaponLabel.Text = weaponModel.Name
					WeaponLabel.TextColor3 = ESP.Drawing.Weapons.RGB
					WeaponLabel.Position = UDim2.new(0, Pos.X, 0, Pos.Y + h / 2 + 9 + verticalOffset)
				else
					WeaponLabel.Visible = false
				end
			else
				WeaponLabel.Visible = false
			end

			-- Health Bar
			if ESP.Drawing.HealthBar.Enabled then
				local barWidth = ESP.Drawing.HealthBar.Width
				local barPosition = ESP.Drawing.HealthBar.Position
				local healthBarHeight = h
				
				local healthBarX = (barPosition == "Left") and (Pos.X - w / 2 - barWidth - 2) or (Pos.X + w / 2 + 2)
				local healthBarY = Pos.Y - healthBarHeight / 2 + verticalOffset
				
				HealthBarContainer.Visible = true
				HealthBarContainer.Position = UDim2.new(0, healthBarX, 0, healthBarY)
				HealthBarContainer.Size = UDim2.new(0, barWidth, 0, healthBarHeight)
				HealthBarFill.Size = UDim2.new(1, 0, healthPercentClamped / 100, 0)
				HealthBarFill.Position = UDim2.new(0, 0, 1 - (healthPercentClamped / 100), 0)
				HealthBarFill.BackgroundColor3 = getHealthColor(healthPercentClamped)
				
				if ESP.Drawing.HealthBar.ShowText then
					HealthBarText.Visible = true
					HealthBarText.Text = string.format("%.0f%%", healthPercentClamped)
					local textX = healthBarX + barWidth / 2
					local textY = healthBarY + healthBarHeight / 2
					HealthBarText.Position = UDim2.new(0, textX, 0, textY)
					HealthBarText.Size = UDim2.new(0, barWidth, 0, 14)
				else
					HealthBarText.Visible = false
				end
			else
				HealthBarContainer.Visible = false
				HealthBarText.Visible = false
			end

			-- Чамсы
			if ESP.Drawing.Chams.Enabled then
				Chams.Enabled = true
				Chams.Adornee = CharacterModel
				Chams.FillColor = ESP.Drawing.Chams.FillRGB
				Chams.OutlineColor = ESP.Drawing.Chams.OutlineRGB
				if ESP.Drawing.Chams.Thermal then
					local breathe_effect = math.atan(math.sin(tick() * 2)) * 2 / math.pi
					Chams.FillTransparency = (ESP.Drawing.Chams.Fill_Transparency / 100) * (1 - (breathe_effect * 0.1))
				end
				Chams.DepthMode = ESP.Drawing.Chams.VisibleCheck and Enum.HighlightDepthMode.Occluded or Enum.HighlightDepthMode.AlwaysOnTop
			else
				Chams.Enabled = false
			end

			-- Скелет
			if ESP.Drawing.Skeleton.Enabled and not ActiveSkeletons[CharacterModel] then
				createSkeletonESP(CharacterModel)
			end

			-- FadeOut
			if ESP.FadeOut.OnDistance then
				local transparency = math.max(0.1, 1 - (Dist / ESP.MaxDistance))
				if Box then Box.BackgroundTransparency = 1 - transparency end
				if NameLabel then NameLabel.TextTransparency = 1 - transparency end
				if WeaponLabel then WeaponLabel.TextTransparency = 1 - transparency end
				if HealthBarContainer then HealthBarContainer.BackgroundTransparency = 1 - transparency end
				if HealthBarText then HealthBarText.TextTransparency = 1 - transparency end
				if Outline then Outline.Transparency = 1 - transparency end
				for _, corner in pairs(corners) do
					corner.BackgroundTransparency = 1 - transparency
				end
			end
		else
			Box.Visible = false
			NameLabel.Visible = false
			WeaponLabel.Visible = false
			HealthBarContainer.Visible = false
			HealthBarText.Visible = false
			Chams.Enabled = false
			for _, corner in pairs(corners) do corner.Visible = false end
		end
	end)
end

local function MonitorPlayers()
	for _, child in pairs(Workspace:GetChildren()) do
		if child:IsA("Model") then
			task.spawn(function()
				task.wait(0.1)
				CreateESP(child)
			end)
		end
	end
	
	Workspace.ChildAdded:Connect(function(child)
		task.wait(0.5)
		if child:IsA("Model") then
			CreateESP(child)
		end
	end)
end

MonitorPlayers()

ESP.RefreshESPs = function()
	for _, espFolder in pairs(ActiveESPs) do
		if espFolder then espFolder:Destroy() end
	end
	ActiveESPs = {}
	MonitorPlayers()
end

ESP.CleanAllESPs = function()
	for _, espFolder in pairs(ActiveESPs) do
		if espFolder then espFolder:Destroy() end
	end
	ActiveESPs = {}
end

ESP.ToggleSkeleton = function(enabled)
	ESP.Drawing.Skeleton.Enabled = enabled
	if not enabled then
		for _, skeletonData in pairs(ActiveSkeletons) do
			if skeletonData and skeletonData.lines then
				for _, line in ipairs(skeletonData.lines) do
					if line then line.Visible = false end
				end
			end
		end
	end
end

ESP.ToggleHealthBar = function(enabled)
	ESP.Drawing.HealthBar.Enabled = enabled
end

ESP.SetHealthBarWidth = function(width)
	if type(width) == "number" and width > 0 then
		ESP.Drawing.HealthBar.Width = width
	end
end

ESP.SetHealthBarPosition = function(position)
	if position == "Left" or position == "Right" then
		ESP.Drawing.HealthBar.Position = position
	end
end

ESP.ToggleHealthBarText = function(enabled)
	ESP.Drawing.HealthBar.ShowText = enabled
end

ESP.SetHealthBarTextSize = function(size)
	if type(size) == "number" and size > 0 then
		ESP.Drawing.HealthBar.TextSize = size
	end
end

ESP.SetHealthColors = function(low, mid, high)
	if low then ESP.Drawing.HealthBar.ColorLow = low end
	if mid then ESP.Drawing.HealthBar.ColorMid = mid end
	if high then ESP.Drawing.HealthBar.ColorHigh = high end
end

return ESP

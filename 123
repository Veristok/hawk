	-- Оружие
	local WeaponLabel = Instance.new("TextLabel")
	WeaponLabel.Name = "WeaponLabel"
	WeaponLabel.Parent = ESPFolder
	WeaponLabel.Position = UDim2.new(0.5, 0, 0, 0)
	WeaponLabel.Size = UDim2.new(0, 100, 0, 20)
	WeaponLabel.AnchorPoint = Vector2.new(0.5, 0.5)
	WeaponLabel.BackgroundTransparency = 1
	WeaponLabel.TextColor3 = ESP.Drawing.Weapons.RGB
	WeaponLabel.Font = Enum.Font.Code
	WeaponLabel.TextSize = ESP.FontSize
	WeaponLabel.TextStrokeTransparency = 0
	WeaponLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
	WeaponLabel.Visible = false

	-- Health Bar
	local HealthBarContainer = Instance.new("Frame")

--[[ Minimal Library - Only Window Framework ]]

local Library = {}
local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local TweenService = game:GetService("TweenService")
local CoreGui = cloneref and cloneref(game:GetService("CoreGui")) or game:GetService("CoreGui")

gethui = gethui or function() return CoreGui end

local LocalPlayer = Players.LocalPlayer
local Camera = Workspace.CurrentCamera

local FromRGB = Color3.fromRGB
local UDim2New = UDim2.new
local Vector2New = Vector2.new

Library = {
    MenuKeybind = "Z",
    Holder = nil,
    NotifHolder = nil,
    Font = nil,
    Theme = {
        ["Window Background"] = FromRGB(43, 43, 43),
        ["Inline"] = FromRGB(12, 12, 12),
        ["Text"] = FromRGB(180, 180, 180),
        ["Border"] = FromRGB(68, 68, 68),
        ["Outline"] = FromRGB(0, 0, 0),
        ["Accent"] = FromRGB(31, 226, 130)
    }
}

-- Window creation (clean, no extra elements)
function Library:Window(Data)
    Data = Data or {}
    local Window = {
        Name = Data.Name or "Window",
        Size = Data.Size or UDim2New(0, 400, 0, 350),
        IsOpen = true
    }
    
    local Outline = Instance.new("Frame")
    Outline.Parent = self.Holder.Instance
    Outline.AnchorPoint = Vector2New(0.5, 0.5)
    Outline.Position = UDim2New(0, Camera.ViewportSize.X / 4, 0, Camera.ViewportSize.Y / 3)
    Outline.Size = Window.Size
    Outline.BackgroundColor3 = self.Theme["Window Background"]
    Outline.BorderSizePixel = 2
    Outline.BorderColor3 = self.Theme["Outline"]
    
    local Inline = Instance.new("Frame")
    Inline.Parent = Outline
    Inline.Position = UDim2New(0, 5, 0, 5)
    Inline.Size = UDim2New(1, -10, 1, -10)
    Inline.BackgroundColor3 = self.Theme["Inline"]
    Inline.BorderSizePixel = 2
    Inline.BorderColor3 = self.Theme["Border"]
    
    -- Make draggable
    local Dragging = false
    local DragStart, StartPosition
    
    Outline.InputBegan:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1 then
            Dragging = true
            DragStart = Input.Position
            StartPosition = Outline.Position
        end
    end)
    
    Outline.InputEnded:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1 then
            Dragging = false
        end
    end)
    
    UserInputService.InputChanged:Connect(function(Input)
        if (Input.UserInputType == Enum.UserInputType.MouseMovement) and Dragging then
            local Delta = Input.Position - DragStart
            Outline.Position = UDim2New(StartPosition.X.Scale, StartPosition.X.Offset + Delta.X, StartPosition.Y.Scale, StartPosition.Y.Offset + Delta.Y)
        end
    end)
    
    function Window:SetOpen(Bool)
        Window.IsOpen = Bool
        Outline.Visible = Bool
    end
    
    UserInputService.InputBegan:Connect(function(Input, GameProcessed)
        if not GameProcessed and (tostring(Input.KeyCode) == self.MenuKeybind or tostring(Input.UserInputType) == self.MenuKeybind) then
            Window:SetOpen(not Window.IsOpen)
        end
    end)
    
    return Window
end

-- Setup GUI holder
do
    local Instances = {}
    function Instances:Create(Class, Props)
        local item = Instance.new(Class)
        for k, v in pairs(Props or {}) do item[k] = v end
        return item
    end
    
    Library.Holder = Instances:Create("ScreenGui", {Parent = gethui(), Name = "\\0", IgnoreGuiInset = true})
    Library.NotifHolder = Instances:Create("Frame", {Parent = Library.Holder, BackgroundTransparency = 1, Size = UDim2New(0.34, 0, 1, -14)})
end

-- Simple notification
function Library:Notification(Text, Duration, Color)
    local notif = Instance.new("Frame")
    notif.Parent = self.NotifHolder
    notif.Size = UDim2New(0, 0, 0, 24)
    notif.BackgroundColor3 = self.Theme["Inline"]
    notif.BorderSizePixel = 2
    notif.BorderColor3 = self.Theme["Outline"]
    notif.AutomaticSize = Enum.AutomaticSize.X
    
    local text = Instance.new("TextLabel")
    text.Parent = notif
    text.Text = Text
    text.FontFace = self.Font
    text.TextSize = 12
    text.TextColor3 = self.Theme["Text"]
    text.BackgroundTransparency = 1
    text.Size = UDim2New(1, 0, 1, 0)
    
    notif.BackgroundTransparency = 1
    notif.Size = UDim2New(0, 0, 0, 0)
    
    task.spawn(function()
        notif:TweenSize(UDim2New(0, 0, 0, 24), "Out", "Back", 0.2, true)
        task.wait(0.1)
        notif.BackgroundTransparency = 0
        task.wait(Duration)
        notif.BackgroundTransparency = 1
        notif:TweenSize(UDim2New(0, 0, 0, 0), "Out", "Back", 0.2, true)
        task.wait(0.5)
        notif:Destroy()
    end)
end

getgenv().Library = Library
return Library

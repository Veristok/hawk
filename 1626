            MakeCorner(Button, 8)
            MakeStroke(Button, Color3.fromRGB(35,40,40), 1)

            Button.MouseButton1Click:Connect(function()
                TweenService:Create(Button, TweenInfo.new(0.08), {
                    BackgroundColor3 = Color3.fromRGB(0,220,200)
                }):Play()

                task.wait(0.08)

                TweenService:Create(Button, TweenInfo.new(0.08), {
                    BackgroundColor3 = Color3.fromRGB(18,22,22)
                }):Play()

                callback()
            end)

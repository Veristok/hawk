                Position = Enabled and UDim2.new(1,-28,0.5,-12) or UDim2.new(0,4,0.5,-12),
                Size = UDim2.new(0,24,0,24)
            })

            MakeCorner(Circle, 99)

            local function Refresh()
                TweenService:Create(Circle, TweenInfo.new(0.16), {
                    Position = Enabled and UDim2.new(1,-28,0.5,-12) or UDim2.new(0,4,0.5,-12),
                    BackgroundColor3 = Enabled and Color3.fromRGB(0,220,200) or Color3.fromRGB(120,120,120)
                }):Play()
            end

            Toggle.MouseButton1Click:Connect(function()
                Enabled = not Enabled
                Refresh()
                callback(Enabled)
            end)

            callback(Enabled)
        end

        function Tab:CreateButton(text, callback)
            callback = callback or function() end

            local Button = Create("TextButton", {
                Parent = Page,
                BackgroundColor3 = Color3.fromRGB(18,22,22),
                BorderSizePixel = 0,
                Size = UDim2.new(1,-25,0,52),
                Text = text,
                Font = Enum.Font.Gotham,
                TextSize = 20,
                TextColor3 = Color3.fromRGB(240,240,240),
                AutoButtonColor = false

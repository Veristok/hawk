    function Window:CreateTab(name)
        local TabButton = Create("TextButton", {
            Parent = TabsHolder,
            BackgroundTransparency = 1,
            Text = name,
            Font = Enum.Font.Gotham,
            TextSize = 26,
            TextColor3 = Color3.fromRGB(180,180,180),
            Size = UDim2.new(1, -10, 0, 46),
            AutoButtonColor = false
        })

        TabButton.TextXAlignment = Enum.TextXAlignment.Left

        local Accent = Create("Frame", {
            Parent = TabButton,
            BackgroundColor3 = Color3.fromRGB(0, 220, 200),
            BorderSizePixel = 0,
            Size = UDim2.new(0, 0, 1, 0)
        })

        local Page = Create("ScrollingFrame", {
            Parent = ContentHolder,
            BackgroundTransparency = 1,
            BorderSizePixel = 0,
            Size = UDim2.new(1, 0, 1, 0),
            Visible = false,
            ScrollBarThickness = 5,
            ScrollBarImageColor3 = Color3.fromRGB(70,70,70),
            CanvasSize = UDim2.new(0,0,0,0)
        })

        local Layout = Create("UIListLayout", {
            Parent = Page,
            Padding = UDim.new(0, 6),
            SortOrder = Enum.SortOrder.LayoutOrder
        })

        Layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            Page.CanvasSize = UDim2.new(0,0,0,Layout.AbsoluteContentSize.Y + 20)
        end)

        local function Select()
            for _,v in pairs(ContentHolder:GetChildren()) do
                if v:IsA("ScrollingFrame") then
                    v.Visible = false
                end
            end

            for _,v in pairs(TabsHolder:GetChildren()) do
                if v:IsA("TextButton") then
                    TweenService:Create(v, TweenInfo.new(0.15), {
                        TextColor3 = Color3.fromRGB(180,180,180)
                    }):Play()

                    local a = v:FindFirstChildOfClass("Frame")
                    if a then
                        TweenService:Create(a, TweenInfo.new(0.15), {
                            Size = UDim2.new(0,0,1,0)
                        }):Play()
                    end
                end
            end

            Page.Visible = true

            TweenService:Create(TabButton, TweenInfo.new(0.15), {
                TextColor3 = Color3.fromRGB(0,220,200)
            }):Play()

            TweenService:Create(Accent, TweenInfo.new(0.15), {
                Size = UDim2.new(0, 3, 1, 0)
            }):Play()
        end

        TabButton.MouseButton1Click:Connect(Select)

        if not CurrentTab then
            CurrentTab = name
            Select()
        end

        local Tab = {}

        function Tab:CreateToggle(text, default, callback)
            callback = callback or function() end

            local Enabled = default or false

            local Holder = Create("Frame", {
                Parent = Page,
                BackgroundTransparency = 1,
                Size = UDim2.new(1, -30, 0, 72)
            })

            local Line = Create("Frame", {
                Parent = Holder,
                BackgroundColor3 = Color3.fromRGB(40,45,45),
                BorderSizePixel = 0,
                Position = UDim2.new(0,0,1,-1),
                Size = UDim2.new(1,0,0,1)
            })

            local Label = Create("TextLabel", {
                Parent = Holder,
                BackgroundTransparency = 1,
                Text = text,
                Font = Enum.Font.Gotham,
                TextSize = 22,
                TextColor3 = Color3.fromRGB(220,220,220),
                Position = UDim2.new(0, 5, 0, 0),
                Size = UDim2.new(0.5,0,1,0),
                TextXAlignment = Enum.TextXAlignment.Left
            })

            local Toggle = Create("TextButton", {
                Parent = Holder,
                Text = "",
                AutoButtonColor = false,
                BackgroundColor3 = Color3.fromRGB(50,50,50),
                BorderSizePixel = 0,
                Position = UDim2.new(1, -75, 0.5, -15),
                Size = UDim2.new(0, 58, 0, 30)
            })


local CustomWindow = {}
local CoreGui = game:GetService("CoreGui")
local UserInputService = game:GetService("UserInputService")
local FromRGB = Color3.fromRGB
local UDim2New = UDim2.new

local Holder = Instance.new("ScreenGui")
Holder.Parent = CoreGui
Holder.Name = "CustomGUI"
Holder.ZIndexBehavior = Enum.ZIndexBehavior.Global

function CustomWindow:Create(Data)
    Data = Data or {}
    
    -- ОСНОВНОЕ ОКНО
    local Outline = Instance.new("Frame")
    Outline.Parent = Holder
    Outline.Size = Data.Size or UDim2New(0, 563, 0, 558)
    Outline.Position = UDim2New(0, 100, 0, 100)
    Outline.BackgroundColor3 = FromRGB(43, 43, 43)
    Outline.BorderSizePixel = 2
    Outline.BorderColor3 = FromRGB(0, 0, 0)
    Outline.Visible = true
    
    -- ВНУТРЕННЯЯ РАМКА
    local Inline = Instance.new("Frame")
    Inline.Parent = Outline
    Inline.Position = UDim2New(0, 5, 0, 5)
    Inline.Size = UDim2New(1, -10, 1, -10)
    Inline.BackgroundColor3 = FromRGB(12, 12, 12)
    Inline.BorderSizePixel = 2
    Inline.BorderColor3 = FromRGB(68, 68, 68)
    
    -- ЗЕЛЕНАЯ ЛИНИЯ СВЕРХУ (просто цвет, без градиента)
    local TopLiner = Instance.new("Frame")
    TopLiner.Parent = Inline
    TopLiner.Position = UDim2New(0, 0, 0, 0)
    TopLiner.Size = UDim2New(1, 0, 0, 2)
    TopLiner.BackgroundColor3 = FromRGB(31, 226, 130)
    TopLiner.BorderSizePixel = 0
    
    -- НАЗВАНИЕ ОКНА
    local Title = Instance.new("TextLabel")
    Title.Parent = Inline
    Title.Text = Data.Name or "Window"
    Title.Position = UDim2New(0, 13, 0, 8)
    Title.Size = UDim2New(0, 150, 0, 25)
    Title.BackgroundTransparency = 1
    Title.TextColor3 = FromRGB(180, 180, 180)
    Title.TextSize = 14
    Title.Font = Enum.Font.GothamSemibold
    Title.TextXAlignment = Enum.TextXAlignment.Left
    Title.TextYAlignment = Enum.TextYAlignment.Center
    
    -- ВЕРТИКАЛЬНАЯ ЛИНИЯ РАЗДЕЛИТЕЛЬ
    local DividerLine = Instance.new("Frame")
    DividerLine.Parent = Inline
    DividerLine.Position = UDim2New(0, 165, 0, 8)
    DividerLine.Size = UDim2New(0, 2, 1, -16)
    DividerLine.BackgroundColor3 = FromRGB(68, 68, 68)
    DividerLine.BorderSizePixel = 0
    
    -- КОНТЕЙНЕР ДЛЯ ТАБОВ
    local TabsContainer = Instance.new("Frame")
    TabsContainer.Parent = Inline
    TabsContainer.Position = UDim2New(0, 13, 0, 40)
    TabsContainer.Size = UDim2New(0, 145, 1, -48)
    TabsContainer.BackgroundTransparency = 1
    
    local TabsScrolling = Instance.new("ScrollingFrame")
    TabsScrolling.Parent = TabsContainer
    TabsScrolling.Size = UDim2New(1, 0, 1, 0)
    TabsScrolling.BackgroundTransparency = 1
    TabsScrolling.ScrollBarThickness = 0
    TabsScrolling.AutomaticCanvasSize = Enum.AutomaticSize.Y
    TabsScrolling.CanvasSize = UDim2New(0, 0, 0, 0)
    
    local TabsLayout = Instance.new("UIListLayout")
    TabsLayout.Parent = TabsScrolling
    TabsLayout.Padding = UDimNew(0, 4)
    TabsLayout.SortOrder = Enum.SortOrder.LayoutOrder
    
    -- ПРАВАЯ ЧАСТЬ (КОНТЕНТ)
    local ContentContainer = Instance.new("ScrollingFrame")
    ContentContainer.Parent = Inline
    ContentContainer.Position = UDim2New(0, 178, 0, 13)
    ContentContainer.Size = UDim2New(1, -191, 1, -26)
    ContentContainer.BackgroundTransparency = 1
    ContentContainer.ScrollBarThickness = 0
    ContentContainer.AutomaticCanvasSize = Enum.AutomaticSize.Y
    ContentContainer.CanvasSize = UDim2New(0, 0, 0, 0)
    
    local ContentLayout = Instance.new("UIListLayout")
    ContentLayout.Parent = ContentContainer
    ContentLayout.Padding = UDimNew(0, 10)
    ContentLayout.SortOrder = Enum.SortOrder.LayoutOrder
    
    -- ХРАНИЛИЩЕ СТРАНИЦ
    local Pages = {}
    
    -- ФУНКЦИЯ ДОБАВЛЕНИЯ СТРАНИЦЫ
    function AddPage(PageName)
        -- КНОПКА ТАБА
        local TabButton = Instance.new("TextButton")
        TabButton.Parent = TabsScrolling
        TabButton.Text = PageName
        TabButton.Size = UDim2New(1, 0, 0, 28)
        TabButton.BackgroundTransparency = 1
        TabButton.TextColor3 = FromRGB(180, 180, 180)
        TabButton.TextSize = 12
        TabButton.Font = Enum.Font.Gotham
        TabButton.TextXAlignment = Enum.TextXAlignment.Left
        TabButton.AutoButtonColor = false
        
        -- ИНДИКАТОР
        local TabIndicator = Instance.new("Frame")
        TabIndicator.Parent = TabButton
        TabIndicator.Position = UDim2New(0, 0, 0, 4)
        TabIndicator.Size = UDim2New(0, 3, 1, -8)
        TabIndicator.BackgroundColor3 = FromRGB(31, 226, 130)
        TabIndicator.BackgroundTransparency = 1
        TabIndicator.BorderSizePixel = 0
        
        -- КОНТЕНТ СТРАНИЦЫ
        local PageContent = Instance.new("Frame")
        PageContent.Parent = ContentContainer
        PageContent.Size = UDim2New(1, 0, 0, 0)
        PageContent.BackgroundTransparency = 1
        PageContent.Visible = false
        PageContent.AutomaticSize = Enum.AutomaticSize.Y
        
        local PageLayout = Instance.new("UIListLayout")
        PageLayout.Parent = PageContent
        PageLayout.Padding = UDimNew(0, 12)
        PageLayout.SortOrder = Enum.SortOrder.LayoutOrder
        
        local PageData = {
            Name = PageName,
            Content = PageContent,
            TabButton = TabButton,
            TabIndicator = TabIndicator,
            Active = false
        }
        
        -- ФУНКЦИЯ АКТИВАЦИИ СТРАНИЦЫ
        function PageData:SetActive(Active)
            PageData.Active = Active
            PageContent.Visible = Active
            
            if Active then
                TabButton.TextColor3 = FromRGB(31, 226, 130)
                TabIndicator.BackgroundTransparency = 0
            else
                TabButton.TextColor3 = FromRGB(180, 180, 180)
                TabIndicator.BackgroundTransparency = 1
            end
        end
        
        -- НАЖАТИЕ НА ТАБ
        TabButton.MouseButton1Click:Connect(function()
            for _, page in pairs(Pages) do
                page:SetActive(false)
            end
            PageData:SetActive(true)
        end)
        
        table.insert(Pages, PageData)
        
        -- АКТИВИРУЕМ ПЕРВУЮ СТРАНИЦУ
        if #Pages == 1 then
            PageData:SetActive(true)
        end
        
        -- ФУНКЦИЯ ДОБАВЛЕНИЯ СЕКЦИИ
        function PageData:AddSection(SectionName)
            local Section = Instance.new("Frame")
            Section.Parent = PageContent
            Section.Size = UDim2New(1, 0, 0, 25)
            Section.BackgroundColor3 = FromRGB(19, 19, 19)
            Section.BorderSizePixel = 2
            Section.BorderColor3 = FromRGB(0, 0, 0)
            Section.AutomaticSize = Enum.AutomaticSize.Y
            
            -- ЗАГОЛОВОК СЕКЦИИ
            local SectionHeader = Instance.new("Frame")
            SectionHeader.Parent = Section
            SectionHeader.Position = UDim2New(0, 2, 0, -2)
            SectionHeader.Size = UDim2New(1, -4, 0, 2)
            SectionHeader.BackgroundColor3 = FromRGB(31, 226, 130)
            SectionHeader.BorderSizePixel = 0
            
            local SectionTitle = Instance.new("TextLabel")
            SectionTitle.Parent = SectionHeader
            SectionTitle.Text = SectionName
            SectionTitle.Position = UDim2New(0, 9, 0, 0)
            SectionTitle.Size = UDim2New(0, 40, 0, 13)
            SectionTitle.BackgroundColor3 = FromRGB(19, 19, 19)
            SectionTitle.TextColor3 = FromRGB(180, 180, 180)
            SectionTitle.TextSize = 12
            SectionTitle.Font = Enum.Font.Gotham
            SectionTitle.AutomaticSize = Enum.AutomaticSize.X
            
            -- КОНТЕЙНЕР ДЛЯ ЭЛЕМЕНТОВ
            local ElementsContainer = Instance.new("Frame")
            ElementsContainer.Parent = Section
            ElementsContainer.Position = UDim2New(0, 12, 0, 17)
            ElementsContainer.Size = UDim2New(1, -24, 1, -20)
            ElementsContainer.BackgroundTransparency = 1
            
            local ElementsLayout = Instance.new("UIListLayout")
            ElementsLayout.Parent = ElementsContainer
            ElementsLayout.Padding = UDimNew(0, 6)
            
            return {
                Container = ElementsContainer,
                AddLabel = function(Text)
                    local Label = Instance.new("TextLabel")
                    Label.Parent = ElementsContainer
                    Label.Text = Text
                    Label.Size = UDim2New(1, 0, 0, 15)
                    Label.BackgroundTransparency = 1
                    Label.TextColor3 = FromRGB(180, 180, 180)
                    Label.TextSize = 12
                    Label.Font = Enum.Font.Gotham
                    Label.TextXAlignment = Enum.TextXAlignment.Left
                    return Label
                end,
                AddButton = function(Text, Callback)
                    local Button = Instance.new("TextButton")
                    Button.Parent = ElementsContainer
                    Button.Text = Text
                    Button.Size = UDim2New(1, 0, 0, 17)
                    Button.BackgroundColor3 = FromRGB(63, 63, 63)
                    Button.TextColor3 = FromRGB(180, 180, 180)
                    Button.TextSize = 12
                    Button.Font = Enum.Font.Gotham
                    Button.AutoButtonColor = false
                    
                    Button.MouseButton1Click:Connect(function()
                        if Callback then Callback() end
                    end)
                    return Button
                end
            }
        end
        
        return PageData
    end
    
    -- DRAG & DROP
    local Dragging = false
    local DragStart
    local StartPosition
    
    Outline.InputBegan:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1 then
            Dragging = true
            DragStart = Input.Position
            StartPosition = Outline.Position
        end
    end)
    
    Outline.InputEnded:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1 then
            Dragging = false
        end
    end)
    
    UserInputService.InputChanged:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseMovement and Dragging then
            local Delta = Input.Position - DragStart
            Outline.Position = UDim2New(StartPosition.X.Scale, StartPosition.X.Offset + Delta.X, StartPosition.Y.Scale, StartPosition.Y.Offset + Delta.Y)
        end
    end)
    
    return {
        Outline = Outline,
        AddPage = AddPage
    }
end

return CustomWindow
